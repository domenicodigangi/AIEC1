# LangGraph agent running the in-memory runtime (`langgraph dev`).
#
# Why in-memory: Vercel container functions are serverless with a ~15s startup
# timeout, ephemeral disk, and scale-to-zero. Booting Postgres + Redis + running
# migrations cannot finish in 15s, so the HTTP port never binds and Vercel kills
# the container. The in-memory runtime skips all of that and binds the port in a
# few seconds. Trade-off: thread/run state is lost on cold start or redeploy.
#
# For durable self-hosting (VPS / Railway / Fly.io), use the full Postgres+Redis
# stack instead (see docker/entrypoint-all-in-one.sh) on an always-on host.
#
# Required env (set in the Vercel project):
#   OPENAI_API_KEY, TAVILY_API_KEY, LANGSMITH_API_KEY

FROM langchain/langgraph-api:3.13

ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

# Install the agent package and dependencies.
ADD . /deps/09_Agent_Servers

RUN for dep in /deps/*; do \
      if [ -d "$dep" ]; then \
        echo "Installing $dep"; \
        (cd "$dep" && PYTHONDONTWRITEBYTECODE=1 uv pip install --system --no-cache-dir -c /api/constraints.txt -e .); \
      fi; \
    done

ENV LANGSERVE_GRAPHS='{"simple_agent": "app.graphs.simple_agent:graph"}'

RUN mkdir -p /api/langgraph_api /api/langgraph_runtime /api/langgraph_license \
    && touch /api/langgraph_api/__init__.py /api/langgraph_runtime/__init__.py /api/langgraph_license/__init__.py \
    && PYTHONDONTWRITEBYTECODE=1 uv pip install --system --no-cache-dir --no-deps -e /api

# Precompile bytecode so cold starts don't pay the .pyc compilation cost on the
# first import (helps stay under the serverless startup timeout).
RUN python -m compileall -q /usr/local/lib/python3.13/site-packages /deps/09_Agent_Servers /api || true

WORKDIR /deps/09_Agent_Servers

COPY docker/entrypoint-inmem.sh /entrypoint-inmem.sh
RUN chmod +x /entrypoint-inmem.sh

EXPOSE 80

ENTRYPOINT ["/entrypoint-inmem.sh"]
