# All-in-one LangGraph agent: API + Redis + Postgres in a single container.
#
# Best for: VPS, Railway, Fly.io, local `docker run`, or any long-lived host.
# NOT recommended for Vercel/serverless — LangGraph explicitly warns against
# serverless (scale-to-zero loses in-flight runs; ephemeral disk resets Postgres).
#
# Required env (set at runtime):
#   OPENAI_API_KEY, TAVILY_API_KEY, LANGSMITH_API_KEY
#
# Optional persistence (recommended for self-hosting):
#   docker run -v langgraph-pg:/var/lib/postgresql/data ...
#
# Regenerate the agent install block after changing langgraph.json:
#   uv run langgraph dockerfile Dockerfile.vercel.tmp && merge manually

FROM langchain/langgraph-api:3.13

ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PGCLIENTENCODING=UTF8

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        redis-server \
        postgresql \
        postgresql-client \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /var/lib/redis /var/lib/postgresql/data /var/run/redis \
    && chown -R redis:redis /var/lib/redis /var/run/redis \
    && chown -R postgres:postgres /var/lib/postgresql/data

# Install the agent package and dependencies.
ADD . /deps/09_Agent_Servers

RUN for dep in /deps/*; do \
      if [ -d "$dep" ]; then \
        echo "Installing $dep"; \
        (cd "$dep" && PYTHONDONTWRITEBYTECODE=1 uv pip install --system --no-cache-dir -c /api/constraints.txt -e .); \
      fi; \
    done

ENV LANGSERVE_GRAPHS='{"simple_agent": "app.graphs.simple_agent:graph"}'

RUN mkdir -p /api/langgraph_api /api/langgraph_runtime /api/langgraph_license \
    && touch /api/langgraph_api/__init__.py /api/langgraph_runtime/__init__.py /api/langgraph_license/__init__.py \
    && PYTHONDONTWRITEBYTECODE=1 uv pip install --system --no-cache-dir --no-deps -e /api

RUN pip uninstall -y pip setuptools wheel \
    && rm -rf /usr/local/lib/python*/site-packages/pip* /usr/local/lib/python*/site-packages/setuptools* /usr/local/lib/python*/site-packages/wheel* \
    && find /usr/local/bin -name "pip*" -delete || true \
    && rm -rf /usr/lib/python*/site-packages/pip* /usr/lib/python*/site-packages/setuptools* /usr/lib/python*/site-packages/wheel* \
    && find /usr/bin -name "pip*" -delete || true \
    && uv pip uninstall --system pip setuptools wheel \
    && rm -f /usr/bin/uv /usr/bin/uvx

WORKDIR /deps/09_Agent_Servers

COPY docker/entrypoint-all-in-one.sh /entrypoint-all-in-one.sh
RUN chmod +x /entrypoint-all-in-one.sh

VOLUME ["/var/lib/postgresql/data", "/var/lib/redis"]

EXPOSE 80

ENTRYPOINT ["/entrypoint-all-in-one.sh"]
