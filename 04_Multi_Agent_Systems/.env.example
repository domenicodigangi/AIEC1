# Copy this file to `.env` (which is git-ignored) and fill in your keys.
# The Session 4 setup cell loads these automatically — no manual prompts needed.

OPENAI_API_KEY=your-openai-key
TAVILY_API_KEY=your-tavily-key
LANGSMITH_API_KEY=your-langsmith-key

# LangSmith tracing. Choose the endpoint that matches your account region:
#   US (default): https://api.smith.langchain.com
#   EU:           https://eu.api.smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=aim-session-4-multi-agent-deep-research



AIM_SEARCH_DEPTH=basic
AIM_SEARCH_CALL_LIMIT=1
AIM_EXTRACT_CALL_LIMIT=1
AIM_WORKER_MODEL_CALL_LIMIT=4